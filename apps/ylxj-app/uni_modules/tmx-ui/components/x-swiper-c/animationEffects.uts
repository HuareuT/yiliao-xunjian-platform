/**
 * 轮播图动画效果模块
 */

/** 轮播项配置 */
export type SwiperItem = {
	/** 轮播项颜色 */
	color: string;
	/** 图片URL */
	image?: string | null;
	/** 其他扩展数据 */
	data?: any | null;
}

/** 动画帧状态 */
export type AnimationFrameState = {
	/** 当前索引 */
	currentIndex: number;
	/** 上一个索引（无可用值时为-1） */
	prevIndex: number;
	/** 下一个索引 */
	nextIndex: number;
	/** 动画进度 0-1 */
	progress: number;
	/** 容器宽度 */
	width: number;
	/** 容器高度 */
	height: number;
	/** 是否垂直方向 */
	vertical: boolean;
	/** 切换方向 1=向前/向下, -1=向后/向上 */
	direction: number;
	/** 是否首尾衔接 */
	circular: boolean;
}

/** 静态状态配置 */
export type AnimationStaticState = {
	/** 当前索引 */
	currentIndex: number;
	/** 上一个索引（无可用值时为-1） */
	prevIndex: number;
	/** 下一个索引（无可用值时为-1） */
	nextIndex: number;
	/** 容器宽度 */
	width: number;
	/** 容器高度 */
	height: number;
	/** 切换方向 */
	direction: number;
	/** 是否首尾衔接 */
	circular: boolean;
	/** 总数 */
	total: number;
}

/** 锚点预设 */
export type AnchorPreset =
	'center'
	| 'left-center'
	| 'right-center'
	| 'top-center'
	| 'bottom-center'
	| 'top-left'
	| 'top-right'
	| 'bottom-left'
	| 'bottom-right';

/** 锚点配置 */
export type AnchorConfig = {
	/**
	 * 锚点预设位置
	 */
	preset?: AnchorPreset;
	/**
	 * 锚点X坐标
	 * - 当 relative 为 true 时，取值0-1表示相对比例
	 * - 当 relative 为 false 或未设置时，表示绝对像素
	 */
	x?: number;
	/**
	 * 锚点Y坐标
	 * - 当 relative 为 true 时，取值0-1表示相对比例
	 * - 当 relative 为 false 或未设置时，表示绝对像素
	 */
	y?: number;
	/**
	 * 是否使用相对比例坐标
	 */
	relative?: boolean;
}

/** 渲染项配置 */
export type RenderItemConfig = {
	/** x坐标 */
	x: number;
	/** y坐标 */
	y: number;
	/** 宽度 */
	width: number;
	/** 高度 */
	height: number;
	/** 透明度 */
	opacity: number;
	/** X轴缩放比例 */
	scaleX: number;
	/** Y轴缩放比例 */
	scaleY: number;
	/** 颜色 */
	color: string;
	/** 轮播项索引 */
	index: number;
	/** 锚点配置 */
	anchor?: AnchorConfig;
	/** 圆角半径 */
	cornerRadius?: number;
	/** 自定义层级（可选，数值越大越靠上） */
	zIndex?: number;
}

type CardState = { x: number; width: number; z: number; height: number; y: number };
type StackingCardStates = {
	left: CardState;
	center: CardState;
	right: CardState;
	hiddenLeft: CardState;
	hiddenRight: CardState;
};
type tempCardsItems = { index: number; state: CardState }
/** 动画效果接口 */
export interface IAnimationEffect {
	/**
	 * 计算动画帧
	 * @param state 动画状态
	 * @param items 轮播项列表
	 * @returns 返回需要渲染的项配置列表
	 */
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[];
	
	/**
	 * 计算静态状态（非动画时的展示状态）
	 * @param state 静态状态信息
	 * @param items 轮播项列表
	 */
	getStaticState(state: AnimationStaticState, items: SwiperItem[]): RenderItemConfig[];
}

/**
 * 缩放平移动画效果
 * 向左平移，当前项从大到小消失，下一项从小到大显示
 */
export class ScaleSlideEffect implements IAnimationEffect {
	/** 最小缩放比例 */
	private minScale: number = 0.8;
	
	constructor(minScale: number = 0) {
		this.minScale = minScale;
	}
	
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, nextIndex, progress, width, height, direction } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length === 0) return result;
		
		const currentItem = items[currentIndex];
		const nextItem = items[nextIndex];
		
		// 计算当前项的缩放和位置
		const currentScale = 1 - (1 - this.minScale) * progress;
		const currentX = -width * progress * direction;
		
		result.push({
		
			x: currentX,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: currentScale,
			scaleY: currentScale,
			color: currentItem.color,
			index: currentIndex
		});
		
		// 计算下一项的缩放和位置
		const nextScale = this.minScale + (1 - this.minScale) * progress;
		const nextX = width * (1 - progress) * direction;
		
		result.push({
	
			x: nextX,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: nextScale,
			scaleY: nextScale,
			color: nextItem.color,
			index: nextIndex
		});
		
		return result;
	}
	
	getStaticState(state: AnimationStaticState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, width, height } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length === 0) return result;
		
		const currentItem = items[currentIndex];
		
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		
		return result;
	}
}

/**
 * 简单滑动效果
 * 水平滑动，无缩放效果，支持正反向
 */
export class SimpleSlideEffect implements IAnimationEffect {
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, nextIndex, progress, width, height, direction } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length == 0) return result;
		
		const currentItem = items[currentIndex];
		const nextItem = items[nextIndex];

		// 当前项滑出（根据方向决定向左或向右）
		result.push({
			x: -width * progress * direction,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex,
			zIndex:1
		});
		
		result.push({
			x: width * (1 - progress) * direction ,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: nextItem.color,
			index: nextIndex,
			zIndex:0
		});
		
		return result;
	}
	
	getStaticState(state: AnimationStaticState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, width, height } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length == 0) return result;
		
		const currentItem = items[currentIndex];
		
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		
		return result;
	}
}
/**
 * 简单滑动效果
 * 垂直滑动，无缩放效果，支持正反向
 */
export class SimpleSlideYEffect implements IAnimationEffect {
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, nextIndex, progress, width, height, direction } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length == 0) return result;
		
		const currentItem = items[currentIndex];
		const nextItem = items[nextIndex];

		// 当前项滑出（根据方向决定向左或向右）
		result.push({
			x: 0,
			y: -height * progress * direction,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		
		// 下一项滑入（根据方向从右侧或左侧）
		result.push({
			x: 0,
			y: height * (1 - progress) * direction,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: nextItem.color,
			index: nextIndex
		});
		
		return result;
	}
	
	getStaticState(state: AnimationStaticState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, width, height } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length == 0) return result;
		
		const currentItem = items[currentIndex];
		
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		
		return result;
	}
}
/**
 * 淡入淡出效果（无方向性）
 */
export class FadeEffect implements IAnimationEffect {
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, nextIndex, progress, width, height, direction } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length == 0) return result;
		
		const currentItem = items[currentIndex];
		const nextItem = items[nextIndex];

		// 下一项淡入（先绘制，作为底层）
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: progress,
			scaleX: 1,
			scaleY: 1,
			color: nextItem.color,
			index: nextIndex
		});
		// #ifndef APP-ANDROID
		// 当前项淡出（后绘制，作为上层）
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: 1-progress,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		// #endif
		return result;
	}
	
	getStaticState(state: AnimationStaticState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, width, height } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length == 0) return result;
		
		const currentItem = items[currentIndex];
		
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		
		return result;
	}
}

/**
 * 水平翻转效果（无方向性）
 * 当前项水平压缩消失，下一项从水平压缩展开
 */
export class FlipXEffect implements IAnimationEffect {
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, nextIndex, progress, width, height, direction } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length === 0) return result;
		
		const currentItem = items[currentIndex];
		const nextItem = items[nextIndex];
		
		// 使用progress判断翻转阶段
		if (progress < 0.5) {
			// 前半段：当前项水平压缩
			const scaleX = 1 - progress * 2;
			result.push({
				x: 0,
				y: 0,
				cornerRadius:16,
				width: width,
				height: height,
				opacity: 1,
				scaleX: scaleX,
				scaleY: 1,
				color: currentItem.color,
				index: currentIndex
			});
		} else {
			// 后半段：下一项水平展开
			const scaleX = (progress - 0.5) * 2;
			result.push({
				x: 0,
				y: 0,
				cornerRadius:16,
				width: width,
				height: height,
				opacity: 1,
				scaleX: scaleX,
				scaleY: 1,
				color: nextItem.color,
				index: nextIndex
			});
		}
		
		return result;
	}
	
	getStaticState(state: AnimationStaticState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, width, height } = state;
		const result: RenderItemConfig[] = [];
		
		if (items.length === 0) return result;
		
		const currentItem = items[currentIndex];
		
		result.push({
			x: 0,
			y: 0,
			width: width,
			height: height,
			opacity: 1,
			scaleX: 1,
			scaleY: 1,
			color: currentItem.color,
			index: currentIndex
		});
		
		return result;
	}
}

/**
 * 垂直翻转效果（无方向性）
 * 当前项垂直压缩消失，下一项从垂直压缩展开
 */
export class FlipYEffect implements IAnimationEffect {
	calculate(state: AnimationFrameState, items: SwiperItem[]): RenderItemConfig[] {
		const { currentIndex, nextIndex, progress, width, height, direction } = state;
