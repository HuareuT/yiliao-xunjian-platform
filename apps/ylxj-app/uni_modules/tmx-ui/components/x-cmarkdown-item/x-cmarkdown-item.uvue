		line-height: 1.5;
		margin-top: 3px;
	}

	.md-list-item-content {
		flex: 1;
		/* line-height: 1.8; */
	}

	/* 水平分割线 */
	.md-hr {
		height: 0.5px;
		background-color: $mdHrColor;
		margin: 15px 0;
	}

	/* 换行 */
	.md-br {
		/* #ifndef APP */
		display: block;
		/* #endif */
		/* #ifdef APP */
		display: flex;
		flex-direction: column;
		width: 100%;
		/* #endif */
	}

	/* 表格 */
	.md-table {
		margin: 10px 0;
		border: 0.5px solid $tableBorderColor;
		border-radius: 5px;
		overflow: hidden;
	}

	.md-table-header {
		display: flex;
		flex-direction: row;
		background-color: $tableHeaderBgColor;
	}
	.md-table-row {
		display: flex;
		flex-direction: row;
		border-top: 0.5px solid $tableBorderColor;
	}
	.md-table-row-ripple{
		background-color: $tableRowreppleBgColor;
	}

	.md-table-cell {
		flex: 1;
		padding: 8px;
		border-right: 0.5px solid $tableBorderColor;
		display: flex;
		flex-direction: column;
		flex-wrap: wrap;
		justify-content: center;
	}

	.md-table-cell-end {
		border-right: none;
	}
	.md-table-cell-left{
		align-items: flex-start;
		
	}
	.md-table-cell-center{
		align-items: center;
	}
	.md-table-cell-right{
		align-items: flex-end;
	}
	
	.softbreak{
		width: 100%;
	}

	/* HTML 和默认 */
	.md-html,
	.md-default {
		margin: 5px 0;
	}
	
	
	
	
	
	/* 文本样式 */
	.md-text.md-text-dark {
		color:$textColorDark;
	}
	
	/* 行内代码 */
	.code-inline.code-inline-dark {
		background-color: $codeLineBgColorDark;
		color:$textColorDark;
	}
	
	/* 代码块 */
	.code-block.code-block-dark {
		background-color: $codeLineBgColorDark;
	}
	.code-lang.code-lang-dark {
		background-color: $codeLangBgcolorDark;
		color: $codeLangColorDark;
	}
	.code-lang-copy.code-lang-copy-dark{
		background-color: $codeLangCopyBgColorDark;
		color: $codeLangCopyColorDark;
	}
	/* 链接 */
	.md-link.md-link-dark {
		color: $codeLinkColorDark;
	}
	
	/* 引用 */
	.md-blockquote.md-blockquote-dark {
		border-left: 4px solid $mdBlockquoteLeftBorderColorDark;
	}
	.blockquoteText.blockquoteText-dark{
		color: $mdBlockquoteLeftColorDark;
	}
	
	.md-task-checkbox.md-task-checkbox-dark {
		border: 0.5px solid $mdTaskCheckboxDark;
		color:$textColorDark;
	}
	
	/* 水平分割线 */
	.md-hr.md-hr-dark {
		background-color: $mdHrColorDark;
	}
	/* 表格 */
	.md-table.md-table-dark {
		border: 0.5px solid $tableBorderColorDark;
	}
	
	.md-table-header.md-table-header-dark {
		background-color: #28282b;
	}
	.md-table-row.md-table-row-dark {
		border-top: 0.5px solid $tableBorderColorDark;
	}
	.md-table-row-ripple.md-table-row-ripple-dark  {
		background-color: #1f1f21;
	}
	
	.md-table-cell.md-table-cell-dark {
		border-right: 0.5px solid $tableBorderColorDark;
	}
	.md-table-cell.md-table-cell-dark {
		border-right: 0.5px solid $tableBorderColorDark;
	}
	.code-lang-code.code-lang-code-dark{
