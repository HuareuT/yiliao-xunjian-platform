{"code":"import { xDateDayInfoType } from \"../../interface\";\nimport { getCurrentLocale, getLocaleData, setLocale } from \"./xDateI18n\";\nconst _regSlash = /\\//g;\nconst _regYYYY = /^(\\d{4})$/;\nconst _regYYMM = /^(\\d{4})[-/](\\d{1,2})$/;\nconst _regYYMMDD = /^(\\d{4})[-/](\\d{1,2})[-/](\\d{1,2})$/;\nconst _regYYMMDDHH = /^(\\d{4})[-/](\\d{1,2})[-/](\\d{1,2}) (\\d{1,2})$/;\nconst _regYYMMDDHHMM = /^(\\d{4})[-/](\\d{1,2})[-/](\\d{1,2}) (\\d{1,2}):(\\d{1,2})$/;\nconst _regYYMMDDHHMMSS = /^(\\d{4})[-/](\\d{1,2})[-/](\\d{1,2}) (\\d{1,2}):(\\d{1,2}):(\\d{1,2})$/;\nconst _regRFC2822 = /^(?:\\w{3},\\s)?(?:\\d{1,2}\\s(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s\\d{4}\\s\\d{2}:\\d{2}(?::\\d{2})?(?:\\sGMT)?)|(?:\\w{3}\\s(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\\s\\d{1,2}\\s\\d{2}:\\d{2}(?::\\d{2})?\\s\\d{4})/;\nconst _regISO8601 = /^\\d{4}(-\\d\\d(-\\d\\d(T\\d\\d:\\d\\d(:\\d\\d)?(\\.\\d+)?(([+-]\\d\\d:\\d\\d)|Z)?)?)?)?$/;\nconst _regDash = /-/g;\nconst _regNumOnly = /^\\d+$/;\nconst _fmtYYYY = /YYYY/g;\nconst _fmtMM = /MM/g;\nconst _fmtDD = /DD/g;\nconst _fmtHH = /hh/g;\nconst _fmtmm = /mm/g;\nconst _fmtSS = /ss/g;\nconst _timeThresholds = [\n    60 * 60 * 24 * 30 * 12 + 60 * 60 * 24 * 30,\n    60 * 60 * 24 * 30 * 12,\n    60 * 60 * 24 * 30 * 6,\n    60 * 60 * 24 * 30 * 5,\n    60 * 60 * 24 * 30 * 4,\n    60 * 60 * 24 * 30 * 3,\n    60 * 60 * 24 * 30 * 2,\n    60 * 60 * 24 * 30,\n    60 * 60 * 24 * 7,\n    60 * 60 * 24 * 2,\n    60 * 60 * 24 * 1,\n    60 * 60 * 23,\n    60 * 60 * 5,\n    60 * 60 * 3,\n    60 * 60 * 2,\n    60 * 60,\n    60 * 30,\n    60 * 10,\n    60 * 5,\n    60,\n    30\n];\nexport class xDateTypeQuarter extends UTS.UTSType {\n    static get$UTSMetadata$() {\n        return {\n            kind: 2,\n            get fields() {\n                return {\n                    quarter: { type: Number, optional: false },\n                    start: { type: String, optional: false },\n                    end: { type: String, optional: false }\n                };\n            },\n            name: \"xDateTypeQuarter\"\n        };\n    }\n    constructor(options, metadata = xDateTypeQuarter.get$UTSMetadata$(), isJSONParse = false) {\n        super();\n        this.__props__ = UTS.UTSType.initProps(options, metadata, isJSONParse);\n        this.quarter = this.__props__.quarter;\n        this.start = this.__props__.start;\n        this.end = this.__props__.end;\n        delete this.__props__;\n    }\n}\n/**\n * 用来解析非标准时间以及各种奇怪的时间格式。\n */\nexport function createDate(dateStrs) {\n    const dateStr = dateStrs.replace(_regSlash, '-');\n    const result = new Date();\n    let year = result.getFullYear();\n    let month = result.getMonth();\n    let day = 1;\n    let hour = 0;\n    let minute = 0;\n    let second = 0;\n    result.setDate(1);\n    let match = dateStr.match(_regYYMMDDHHMMSS);\n    if (match != null) {\n        year = parseInt(match[1]);\n        month = parseInt(match[2]) - 1;\n        day = parseInt(match[3]);\n        hour = parseInt(match[4]);\n        minute = parseInt(match[5]);\n        second = parseInt(match[6]);\n    }\n    else {\n        match = dateStr.match(_regYYMMDDHHMM);\n        if (match != null) {\n            year = parseInt(match[1]);\n            month = parseInt(match[2]) - 1;\n            day = parseInt(match[3]);\n            hour = parseInt(match[4]);\n            minute = parseInt(match[5]);\n        }\n        else {\n            match = dateStr.match(_regYYMMDDHH);\n            if (match != null) {\n                year = parseInt(match[1]);\n                month = parseInt(match[2]) - 1;\n                day = parseInt(match[3]);\n                hour = parseInt(match[4]);\n            }\n            else {\n                match = dateStr.match(_regYYMMDD);\n                if (match != null) {\n                    year = parseInt(match[1]);\n                    month = parseInt(match[2]) - 1;\n                    day = parseInt(match[3]);\n                }\n                else {\n                    match = dateStr.match(_regYYMM);\n                    if (match != null) {\n                        year = parseInt(match[1]);\n                        month = parseInt(match[2]) - 1;\n                    }\n                    else {\n                        match = dateStr.match(_regYYYY);\n                        if (match != null) {\n                            year = parseInt(match[1]);\n                        }\n                    }\n                }\n            }\n        }\n    }\n    result.setSeconds(second);\n    result.setMinutes(minute);\n    result.setHours(hour);\n    result.setFullYear(year);\n    result.setMonth(month);\n    result.setDate(day);\n    return result;\n}\n/**\n * 日期库 xDate\n */\nexport class xDate {\n    /**\n     * dateStr,可能是数字，字符串，Date对象\n     */\n    constructor(dateStr = null) {\n        this.date = this.checkDate(dateStr);\n    }\n    checkDate(dateStr = null) {\n        let tempDate = new Date();\n        if (dateStr == null) {\n            return tempDate;\n        }\n        if (typeof dateStr == 'number') {\n            return new Date(dateStr);\n        }\n        else if (typeof dateStr == 'string') {\n            if (dateStr == '') {\n                return tempDate;\n            }\n            const dateformatStr = this.detectDateFormat(dateStr);\n            if (dateformatStr == 'CUSTOM') {\n                let str = dateStr;\n                str = str.replace(_regDash, '/');\n                let isNumberStr = _regNumOnly.test(str);\n                if (!isNumberStr) {\n                    return createDate(dateStr);\n                }\n                else {\n                    // 长度为 8 的纯数字视为 YYYYMMDD 日期格式，其他按时间戳解析\n                    if (str.length == 8) {\n                        return createDate(str.substring(0, 4) + '/' + str.substring(4, 6) + '/' + str.substring(6, 8));\n                    }\n                    return new Date(parseInt(str));\n                }\n            }\n            else {\n                return new Date(dateStr);\n            }\n        }\n        else if (UTS.isInstanceOf(dateStr, Date)) {\n            return dateStr;\n        }\n        return tempDate;\n    }\n    /**\n     * 检测字符串的日期格式类型\n     * @param dateStr - 日期字符串\n     * @returns 日期格式类型\n     */\n    detectDateFormat(dateStr) {\n        if (_regRFC2822.test(dateStr)) {\n            return 'RFC2822';\n        }\n        if (_regISO8601.test(dateStr)) {\n            return 'ISO8601';\n        }\n        return 'CUSTOM';\n    }\n    /**\n     * 给数字添加前缀0\n     */\n    translateFullDate(d, w) {\n        let dstr = d.toString();\n        while (dstr.length < w) {\n            dstr = '0' + dstr;\n        }\n        return dstr;\n    }\n    /**\n     * 格式化日期\n     * @param {string} s 模板，比如YYYY/MM/DD hh:mm:ss\n     * @returns {string} 格式化后的日期字符串\n     */\n    format(s = null) {\n        let str = s != null ? s : \"YYYY/MM/DD hh:mm:ss\";\n        str = str.replace(_fmtYYYY, this.translateFullDate(this.date.getFullYear(), 4));\n        str = str.replace(_fmtMM, this.translateFullDate(this.date.getMonth() + 1, 2));\n        str = str.replace(_fmtDD, this.translateFullDate(this.date.getDate(), 2));\n        str = str.replace(_fmtHH, this.translateFullDate(this.date.getHours(), 2));\n        str = str.replace(_fmtmm, this.translateFullDate(this.date.getMinutes(), 2));\n        str = str.replace(_fmtSS, this.translateFullDate(this.date.getSeconds(), 2));\n        return str;\n    }\n    /**\n     * 获取当前年\n     * @return — 根据当地时间，返回一个对应于给定日期的年份数字。\n     */\n    getYear() {\n        return this.date.getFullYear();\n    }\n    /**\n     * 获取当前月\n     * @description 是从0开始，1-11月\n     * @return — 一个 0 到 11 的整数值：0 代表一月份，1 代表二月份，2 代表三月份，依次类推\n     */\n    getMonth() {\n        return this.date.getMonth();\n    }\n    /**\n     * 获取当前月份的名称\n     * @param {boolean} useShort - 是否使用短名称\n     * @return — 返回当前语言环境下的月份名称\n     */\n    getMonthName(useShort = false) {\n        const monthIndex = this.date.getMonth();\n        return useShort ?\n            getLocaleData().monthsShort[monthIndex] :\n            getLocaleData().months[monthIndex];\n    }\n    /**\n     * 获取当前天\n     * @return — 返回一个 1 到 31 的整数值。\n     */\n    getDate() {\n        return this.date.getDate();\n    }\n    /**\n     * 获取当前小时\n     * @return — 返回一个 0 到 23 之间的整数值。\n     */\n    getHours() {\n        return this.date.getHours();\n    }\n    /**\n     * 获取当前分钟\n     * @return — 返回一个 0 到 59 的整数值。\n     */\n    getMinutes() {\n        return this.date.getMinutes();\n    }\n    /**\n     * 获取当前秒\n     * @return — 返回一个 0 到 59 的整数值。\n     */\n    getSeconds() {\n        return this.date.getSeconds();\n    }\n    /**\n     * 获取指定是数据\n     * @param {xDateTypeTime} d - 'y' 年 'm' 月 'd' 日 'h' 时 'M' 分 's' 秒 'ms' 毫秒\n     * @returns - 指定类型的数值\n     */\n    getDateOf(d = 'd') {\n        if (d == 'y') {\n            return this.date.getFullYear();\n        }\n        else if (d == 'm') {\n            return this.date.getMonth();\n        }\n        else if (d == 'd') {\n            return this.date.getDate();\n        }\n        else if (d == 'h') {\n            return this.date.getHours();\n        }\n        else if (d == 'M') {\n            return this.date.getMinutes();\n        }\n        else if (d == 's') {\n            return this.date.getSeconds();\n        }\n        return this.date.getMilliseconds();\n    }\n    /**\n     * 设定日期\n     * @param {number} n - 设定的数据,\n     * @param {string} d - 比如d=y，那么就是设置本日期的年份数据,'y' 年 'm' 月 'd' 日 'h' 时 'M' 分 's' 秒 'ms' 毫秒\n     * @returns - xDate对象实例\n     */\n    setDateOf(n, d = 'd') {\n        if (d == 'y') {\n            this.date.setFullYear(n);\n        }\n        else if (d == 'm') {\n            this.date.setMonth(n);\n        }\n        else if (d == 'd') {\n            this.date.setDate(n);\n        }\n        else if (d == 'h') {\n            this.date.setHours(n);\n        }\n        else if (d == 'M') {\n            this.date.setMinutes(n);\n        }\n        else if (d == 's') {\n            this.date.setSeconds(n);\n        }\n        else if (d == 'ms') {\n            this.date.setMilliseconds(n);\n        }\n        return this;\n    }\n    /**\n     * @param {string} - d:'y' 年 'm' 月 'd' 日 'h' 时 'M' 分 's' 秒 'ms' 毫秒\n     * @returns - 返回从UTC时间1970年1月1日午夜开始以毫秒为单位存储的时间值。\n     * @description 注意，如果不提供d就默认返回毫秒，比如设置d=m那么后面的h,M,s,ms会被设置为0\n     */\n    getTime(d) {\n        let date = new Date(this.date.getTime());\n        if (d == 'y') {\n            date.setMonth(0);\n            date.setDate(1);\n            date.setHours(0);\n            date.setMinutes(0);\n            date.setSeconds(0);\n            date.setMilliseconds(0);\n            return date.getTime();\n        }\n        else if (d == 'm') {\n            date.setDate(1);\n            date.setHours(0);\n            date.setMinutes(0);\n            date.setSeconds(0);\n            date.setMilliseconds(0);\n            return date.getTime();\n        }\n        else if (d == 'd') {\n            date.setHours(0);\n            date.setMinutes(0);\n            date.setSeconds(0);\n            date.setMilliseconds(0);\n            return date.getTime();\n        }\n        else if (d == 'h') {\n            date.setMinutes(0);\n            date.setSeconds(0);\n            date.setMilliseconds(0);\n            return date.getTime();\n        }\n        else if (d == 'M') {\n            date.setSeconds(0);\n            date.setMilliseconds(0);\n            return date.getTime();\n        }\n        else if (d == 's') {\n            date.setMilliseconds(0);\n            return date.getTime();\n        }\n        return date.getTime();\n    }\n    /**\n     * 当前时间的副本\n     */\n    getClone() {\n        return new xDate(this.date.getTime());\n    }\n    /**\n     * 本年的第几周\n     * @return 周次\n     */\n    getWeek() {\n        let target = new Date(this.date.getTime());\n        target.setDate(target.getDate() - (target.getDay() == 0 ? 7 : target.getDay()));\n        let firstDayOfYear = new Date(target.getFullYear(), 0, 1);\n        firstDayOfYear.setDate(firstDayOfYear.getDate() - (firstDayOfYear.getDay() == 0 ? 7 : firstDayOfYear.getDay()));\n        return Math.ceil((((target.getTime() - firstDayOfYear.getTime()) / 86400000) + 1) / 7);\n    }\n    /**\n     * 取时间的第一天\n     * @param {m,w,y} - m表示取本月的第一天，w取本周的第一天,y表示本年的第一天\n     * @returns {xDate} - 返回xDate对象\n     */\n    getDateStartOf(d = 'm') {\n        let now = new Date(this.date.getTime());\n        if (d == 'w') {\n            // 将日期设置为所在周的周一（遵循ISO 8601标准，周一开始于周一）\n            let dayOfWeek = now.getDay();\n            if (dayOfWeek === 0) { // 如果是星期日，则向前推一天至上周的周一\n                now.setDate(now.getDate() - 7);\n            }\n            now.setDate(now.getDate() - dayOfWeek + 1);\n        }\n        if (d == 'm' || d == 'y') {\n            now.setDate(1);\n        }\n        if (d == 'y') {\n            now.setMonth(0);\n        }\n        now.setHours(0);\n        now.setMinutes(0);\n        now.setSeconds(0);\n        now.setMilliseconds(0);\n        return dateCovertXdate(now);\n    }\n    /**\n     * 取时间的最后一天\n     * @param {string} - m,w,y m表示取本月的最后一天，w取本周的最后一天,y表示本年的最后一天\n     * @returns {xDate} - 返回xDate对象\n     */\n    getDateEndOf(d = 'm') {\n        // 获取当前日期对象\n        let now = new Date(this.date.getTime());\n        if (d == 'w') {\n            let dayOfWeek = now.getDay();\n            if (dayOfWeek === 0) {\n                now.setHours(23);\n                now.setMinutes(59);\n                now.setSeconds(59);\n                now.setMilliseconds(999);\n                return dateCovertXdate(now);\n            }\n            now.setDate(now.getDate() + (7 - dayOfWeek));\n        }\n        if (d == 'm') {\n            now.setDate(this.getMonthCountDay());\n        }\n        if (d == 'y') {\n            // 先设置月份为12月，再设置为该月的最后一天\n            now.setMonth(11);\n            // 设置为12月的最后一天\n            now.setD