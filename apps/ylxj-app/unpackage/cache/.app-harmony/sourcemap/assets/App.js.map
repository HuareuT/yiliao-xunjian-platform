
<script lang="uts">
	export default {
		onLaunch: function () {
			// 配置app及web字体，必须

			uni.loadFontFace({
				global: true,
				family: 'remixicon',
				source: "url('/static/tmui4xLibs/static/remixicon.ttf')",
				success() {
					uni.setStorageSync("loadedFontBytmx", "true")
					uni.__f__('log','at App.uvue:13','global loadFontFace uni.ttf success===')
				},
				fail(error) {
					uni.setStorageSync("loadedFontBytmx", "")
					uni.__f__('warn','at App.uvue:17','global loadFontFace uni.ttf fail--', error.errMsg)
				},
			})

		},
		onShow: function () { },
		onHide: function () { },
		onLastPageBackPress: function () { },
		onExit: function () { },
	}
</script>



<style>
    /* (可选)引用样式文件,下面两个二选一即可，默认使用px单位，如果你有自己的原子css库插件，
	你可以不引用本css库，可以删除不影响组件 */
