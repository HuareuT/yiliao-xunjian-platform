type ATTRGERTS = {
	from : string,
	to : string,
	unit : string,
	now : string,
	progress : number,
	name : string
}
type callbackFunType = (x:number)=>number
type easingFunType = {
	x:number,
	y:number,
	m:number,
	n:number,
}

export class xAnimate {
