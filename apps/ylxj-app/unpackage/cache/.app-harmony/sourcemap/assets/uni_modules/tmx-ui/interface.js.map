	header : UTSJSONObject | null,
	/**
	 * 开了调试模式后，你能查看所有的请求日志并统计当前的
	 * 请求总数，及每次请求的时间
	 * 及请求的状态值。
	 */
	dev : boolean,
	showLoadToast : boolean,
	/** 请求成功后是否提示，否则不提示 */
	showSuccessToast : boolean,
	/** 出错时，是否显示提示,否则不提示 */
	showErrorToast : boolean
}

