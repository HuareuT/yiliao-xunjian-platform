	/** 动画类型 */
	timingFunction ?: string,
	/** -1表示无限循环播放，0表示不会播放，大于0表示播放该次数后停止播放 */
	loop ?: number,
	/** 表示循环播放时，是否左右来回播放，而不是始终从开始到结束这样的状态播放 */
