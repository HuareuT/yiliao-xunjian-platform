	/** 四位数数组的动画映射值,优先级高于timingFunction */
	bezier ?: number[],
	/** 动画结束后的回调函数 */
	complete ?: () => void,
	/** 动画开始 */
	start ?: () => void,
	/** 动画运行中执行 */
	frame ?: (propress : number) => void
}

